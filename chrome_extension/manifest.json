{
  "manifest_version": 3,
  "name": "YouTube Content Quality Analyzer",
  "version": "2.1",
  "description": "Analyzes YouTube comments with AI to determine the true content quality of any video. Includes Learn More with Gemini AI.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:8080/*",
    "https://*.onrender.com/*",
    "https://*.youtube.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*"
      ],
      "js": [
        "chart.min.js",
        "content.js"
      ],
      "css": [
        "style.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "learn.html",
        "learn.js",
        "learn.css"
      ],
      "matches": [
        "*://*.youtube.com/*"
      ]
    }
  ]
}
